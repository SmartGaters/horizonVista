    {
      "parameters": {
        "jsCode": "// Get AI output (adjust field if needed)\nlet text = $json.output || \"\";\n\n// 1. Normalize quotes and remove weird unicode\ntext = text\n  .replace(/[“”]/g, '\"')\n  .replace(/[‘’]/g, \"'\")\n  .replace(/\\u200B/g, '')   // zero-width space\n  .replace(/\\u200C/g, '')\n  .replace(/\\u200D/g, '')\n  .replace(/\\uFEFF/g, '');\n\n// 2. Escape Telegram MarkdownV2 special characters\nconst escapeChars = [\n  '_', '*', '[', ']', '(', ')', '~', '`', '>', '#', '+', '-', '=', '|', '{', '}', '.', '!'\n];\n\nescapeChars.forEach(char => {\n  const regex = new RegExp(`\\\\${char}`, 'g');\n  text = text.replace(regex, `\\\\${char}`);\n});\n\n// 3. Restore simple formatting (optional)\n// Allow *bold* only (remove escaping around it)\ntext = text.replace(/\\\\\\*(.*?)\\\\\\*/g, '*$1*');\n\n// 4. Clean excessive backslashes (just in case)\ntext = text.replace(/\\\\\\\\/g, '\\\\');\n\n// 5. Trim\ntext = text.trim();\n\n// Return cleaned text\nreturn [\n  {\n    json: {\n      text: text\n    }\n  }\n];"
      },
